---
import Layout from '@layouts/error.astro';
---

<Layout>
	<main class="flex max-w-lg flex-col items-center gap-6 px-4 sm:flex-row sm:px-6 lg:px-8">
		<h1 class="text-4xl font-semibold tracking-tight text-gray-900 dark:text-white">
			{'{{.Code}}'}
		</h1>
		<div
			class="flex w-full gap-x-8 px-6 py-2 text-sm/6 font-medium sm:order-0 sm:w-auto sm:border-l sm:border-gray-200 sm:px-0 sm:pl-6 sm:text-sm/7 dark:sm:border-white/15"
		>
			<p class="text-gray-500 dark:text-gray-400">{'{{.Message}}'}</p>
		</div>
	</main>
</Layout>
