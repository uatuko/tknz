{
  "name": "tknz",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:app && npm run build:tmpl",
    "build:app": "cd app && npm run build",
    "build:tmpl": "cd tmpl && npm run build",
    "format": "prettier --write .",
    "install:app": "cd app && npm install",
    "install:tmpl": "cd tmpl && npm install",
    "postinstall": "npm run install:app && npm run install:tmpl",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write ."
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-plugin-svelte": "^3.15.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2"
  }
}
